    {
      "id": "TC-056",
      "name": "Clicking canvas (pane) closes Properties Panel",
      "priority": "high",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "click", "target": ".react-flow__pane", "offsetX": 100, "offsetY": 100 }
      ],
      "assertions": [
        { "type": "notVisible", "target": "[data-testid='properties-panel']", "description": "Properties panel hidden after clicking canvas" }
      ]
    },
    {
      "id": "TC-057",
      "name": "Properties Panel collapsible sections work",
      "priority": "medium",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "click", "target": "[data-testid='collapsible-section-frontmatter'] [data-testid='section-toggle']" }
      ],
      "assertions": [
        { "type": "notVisible", "target": "[data-testid='collapsible-section-frontmatter'] [data-testid='section-content']", "description": "Section content hidden after collapse" }
      ]
    }
  ]
