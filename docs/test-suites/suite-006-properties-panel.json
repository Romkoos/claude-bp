        { "action": "click", "target": ".react-flow__node[data-type='subagent']" }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='subagent-editor']", "description": "Subagent editor rendered" },
        { "type": "visible", "target": "[data-testid='field-subagent-system-prompt']", "description": "System prompt field visible" },
        { "type": "visible", "target": "[data-testid='field-subagent-agent-type']", "description": "Agent type dropdown visible" }
      ]
    },
    {
      "id": "TC-052",
      "name": "Clicking a Hook node opens Hook editor",
