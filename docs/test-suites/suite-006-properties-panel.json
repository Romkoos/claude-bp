      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='rules-editor']", "description": "Rules editor rendered" },
        { "type": "visible", "target": "[data-testid='field-rules-scope']", "description": "Scope field visible" },
        { "type": "visible", "target": "[data-testid='field-rules-content']", "description": "Content editor visible" }
      ]
