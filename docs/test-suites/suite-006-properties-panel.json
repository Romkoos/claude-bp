    {
      "id": "TC-056",
      "name": "Clicking canvas (pane) closes Properties Panel",
      "priority": "high",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "click", "target": ".react-flow__pane", "offsetX": 100, "offsetY": 100 }
      ],
      "assertions": [
        { "type": "notVisible", "target": "[data-testid='properties-panel']", "description": "Properties panel hidden after clicking canvas" }
      ]
    },
    {
      "id": "TC-057",
      "name": "Properties Panel collapsible sections work",
      "priority": "medium",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "click", "target": "[data-testid='collapsible-section-frontmatter'] [data-testid='section-toggle']" }
      ],
      "assertions": [
        { "type": "notVisible", "target": "[data-testid='collapsible-section-frontmatter'] [data-testid='section-content']", "description": "Section content hidden after collapse" }
      ]
    },
    {
      "id": "TC-314",
      "name": "Skill context selector shows Inline and Fork options",
      "priority": "high",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" }
      ],
      "assertions": [
        { "type": "textContains", "target": "[data-testid='field-skill-context']", "expected": "Inline", "description": "Context selector shows Inline option" }
      ]
    },
    {
      "id": "TC-315",
      "name": "Skill model selector shows correct options",
      "priority": "high",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='field-skill-model']", "description": "Model selector is visible with Not set/Sonnet/Opus/Haiku options" }
      ]
    },
    {
      "id": "TC-316",
      "name": "Skill argument hint field accepts text input",
      "priority": "medium",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "type", "target": "[data-testid='field-skill-argument-hint'] input", "value": "test-hint" }
      ],
      "assertions": [
        { "type": "value", "target": "[data-testid='field-skill-argument-hint'] input", "expected": "test-hint", "description": "Argument hint field accepts text" }
      ]
    },
    {
      "id": "TC-317",
      "name": "Skill disable model invocation checkbox toggles",
      "priority": "medium",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "click", "target": "[data-testid='field-skill-disable-model-invocation'] input" }
      ],
      "assertions": [
        { "type": "checked", "target": "[data-testid='field-skill-disable-model-invocation'] input", "description": "Disable model invocation checkbox can be checked" }
      ]
    },
    {
