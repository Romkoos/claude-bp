{
  "id": "SUITE-006",
  "name": "Node Selection & Properties Panel",
  "tests": [
    {
      "id": "TC-050",
      "name": "Clicking a Skill node opens Properties Panel with Skill editor",
      "priority": "critical",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='properties-panel']", "description": "Properties panel appears" },
        { "type": "visible", "target": "[data-testid='skill-editor']", "description": "Skill-specific editor rendered" },
        { "type": "visible", "target": "[data-testid='field-skill-name']", "description": "Skill name field visible" },
        { "type": "visible", "target": "[data-testid='field-skill-description']", "description": "Skill description field visible" },
        { "type": "visible", "target": "[data-testid='field-skill-context']", "description": "Skill context dropdown visible" },
        { "type": "visible", "target": "[data-testid='field-skill-model']", "description": "Skill model selector visible" },
        { "type": "visible", "target": "[data-testid='field-skill-argument-hint']", "description": "Skill argument hint field visible" },
        { "type": "visible", "target": "[data-testid='field-skill-disable-model-invocation']", "description": "Disable model invocation checkbox visible" },
        { "type": "visible", "target": "[data-testid='field-skill-user-invocable']", "description": "User invocable checkbox visible" },
        { "type": "visible", "target": "[data-testid='field-skill-allowed-tools']", "description": "Allowed tools multi-select visible" }
      ]
    },
    {
      "id": "TC-051",
      "name": "Clicking a Subagent node opens Subagent editor",
      "priority": "critical",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-subagent']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='subagent']" }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='subagent-editor']", "description": "Subagent editor rendered" },
        { "type": "visible", "target": "[data-testid='field-subagent-system-prompt']", "description": "System prompt field visible" },
        { "type": "visible", "target": "[data-testid='field-subagent-agent-type']", "description": "Agent type dropdown visible" }
      ]
    },
    {
      "id": "TC-052",
      "name": "Clicking a Hook node opens Hook editor",
      "priority": "critical",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-hook']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='hook']" }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='hook-editor']", "description": "Hook editor rendered" },
        { "type": "visible", "target": "[data-testid='field-hook-event']", "description": "Event dropdown visible" },
        { "type": "visible", "target": "[data-testid='field-hook-matcher']", "description": "Matcher field visible" },
        { "type": "visible", "target": "[data-testid='field-hook-command']", "description": "Command field visible" },
        { "type": "visible", "target": "[data-testid='field-hook-decision']", "description": "Decision type dropdown visible" }
      ]
    },
    {
      "id": "TC-053",
      "name": "Clicking a Rules node opens Rules editor",
