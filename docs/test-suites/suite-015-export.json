{
  "id": "SUITE-015",
  "name": "Export — File System (.claude/ ZIP)",
  "tests": [
    {
      "id": "TC-140",
      "name": "Export button opens Export Preview modal",
      "priority": "critical",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "click", "target": "[data-testid='template-starter']" },
        { "action": "click", "target": "[data-testid='confirm-load-template']" },
        { "action": "click", "target": "[data-testid='toolbar-export']" }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='export-preview-modal']", "description": "Export preview modal opens" },
        { "type": "visible", "target": "[data-testid='export-file-tree']", "description": "File tree visible" },
        { "type": "visible", "target": "[data-testid='export-download-zip']", "description": "Download ZIP button visible" }
      ]
    },
    {
      "id": "TC-141",
      "name": "Export file tree co-locates rules with linked skill",
      "priority": "critical",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "click", "target": "[data-testid='template-starter']" },
        { "action": "click", "target": "[data-testid='confirm-load-template']" },
        { "action": "click", "target": "[data-testid='toolbar-export']" }
      ],
      "assertions": [
        { "type": "textContains", "target": "[data-testid='export-file-tree']", "expected": "project-rules.md", "description": "Rules file named from node label in tree" }
      ]
    },
    {
      "id": "TC-142",
      "name": "Export file tree contains SKILL.md for Skill nodes",
      "priority": "critical",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "click", "target": "[data-testid='template-starter']" },
        { "action": "click", "target": "[data-testid='confirm-load-template']" },
        { "action": "click", "target": "[data-testid='toolbar-export']" }
      ],
      "assertions": [
        { "type": "textContains", "target": "[data-testid='export-file-tree']", "expected": "SKILL.md", "description": "SKILL.md file in tree" },
        { "type": "textContains", "target": "[data-testid='export-file-tree']", "expected": "skills", "description": ".claude/skills/ directory in tree" }
      ]
    },
    {
      "id": "TC-143",
      "name": "Clicking file in tree shows content preview",
      "priority": "high",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-rules']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": "[data-testid='toolbar-export']" },
        { "action": "wait_for_timeout", "timeout": 500 }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='export-content-preview']", "description": "Content preview panel visible" }
      ]
    },
    {
      "id": "TC-144",
      "name": "Export preview shows generated file content",
      "priority": "high",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": "[data-testid='toolbar-export']" },
        { "action": "wait_for_timeout", "timeout": 500 }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='export-preview-modal']", "description": "Export modal visible" },
        { "type": "visible", "target": "[data-testid='export-file-tree']", "description": "File tree visible" }
      ]
    },
    {
      "id": "TC-145",
      "name": "Export with PR Review template generates agents/*.md and settings.json",
      "priority": "high",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "click", "target": "[data-testid='template-pr-review']" },
        { "action": "click", "target": "[data-testid='confirm-load-template']" },
        { "action": "click", "target": "[data-testid='toolbar-export']" }
      ],
      "assertions": [
        { "type": "textContains", "target": "[data-testid='export-file-tree']", "expected": "agents", "description": ".claude/agents/ directory present" },
        { "type": "textContains", "target": "[data-testid='export-file-tree']", "expected": "settings.json", "description": "settings.json present (for hooks)" }
      ]
    },
    {
      "id": "TC-308",
      "name": "Exported skill file contains MANDATORY integration section when connected",
      "priority": "high",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "click", "target": "[data-testid='template-starter']" },
        { "action": "click", "target": "[data-testid='confirm-load-template']" },
        { "action": "click", "target": "[data-testid='toolbar-export']" },
        { "action": "wait_for_timeout", "timeout": 500 },
        { "action": "click", "target": "[data-testid='export-file-tree'] >> text=SKILL.md >> nth=0" }
      ],
      "assertions": [
        { "type": "textContains", "target": "[data-testid='export-content-preview']", "expected": "MANDATORY", "description": "Skill file contains MANDATORY integration section" },
        { "type": "textContains", "target": "[data-testid='export-content-preview']", "expected": "project-rules.md", "description": "Integration section references the co-located rules file" }
      ]
    },
    {
      "id": "TC-146",
      "name": "Download ZIP button triggers file download",
      "priority": "critical",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "click", "target": "[data-testid='template-starter']" },
        { "action": "click", "target": "[data-testid='confirm-load-template']" },
        { "action": "click", "target": "[data-testid='toolbar-export']" },
        { "action": "interceptDownload", "filename": "*.zip" },
        { "action": "click", "target": "[data-testid='export-download-zip']" }
      ],
      "assertions": [
        { "type": "downloadTriggered", "filenamePattern": ".claude-config.zip", "description": "ZIP file download triggered" }
      ]
    },
    {
      "id": "TC-319",
      "name": "Exported skill frontmatter includes argument-hint when set",
      "priority": "high",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "clear", "target": "[data-testid='field-skill-name'] input" },
        { "action": "type", "target": "[data-testid='field-skill-name'] input", "value": "test-export-skill" },
        { "action": "type", "target": "[data-testid='field-skill-argument-hint'] input", "value": "provide a file path" },
        { "action": "click", "target": "[data-testid='toolbar-export']" },
        { "action": "wait_for_timeout", "timeout": 500 },
        { "action": "click", "target": "[data-testid='export-file-tree'] >> text=SKILL.md >> nth=0" }
      ],
      "assertions": [
        { "type": "textContains", "target": "[data-testid='export-content-preview']", "expected": "argument-hint", "description": "Exported frontmatter contains argument-hint field" }
      ]
    },
    {
      "id": "TC-320",
      "name": "Exported skill frontmatter includes disable-model-invocation when enabled",
      "priority": "high",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "clear", "target": "[data-testid='field-skill-name'] input" },
        { "action": "type", "target": "[data-testid='field-skill-name'] input", "value": "no-model-skill" },
        { "action": "click", "target": "[data-testid='field-skill-disable-model-invocation'] input" },
        { "action": "click", "target": "[data-testid='toolbar-export']" },
        { "action": "wait_for_timeout", "timeout": 500 },
        { "action": "click", "target": "[data-testid='export-file-tree'] >> text=SKILL.md >> nth=0" }
      ],
      "assertions": [
        { "type": "textContains", "target": "[data-testid='export-content-preview']", "expected": "disable-model-invocation", "description": "Exported frontmatter contains disable-model-invocation field" }
      ]
    },
    {
      "id": "TC-321",
      "name": "Exported skill frontmatter includes user-invocable:false when unchecked",
      "priority": "high",
      "phase": 3,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-skill']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 },
        { "action": "click", "target": ".react-flow__node[data-type='skill']" },
        { "action": "clear", "target": "[data-testid='field-skill-name'] input" },
        { "action": "type", "target": "[data-testid='field-skill-name'] input", "value": "internal-skill" },
        { "action": "click", "target": "[data-testid='field-skill-user-invocable'] input" },
        { "action": "click", "target": "[data-testid='toolbar-export']" },
        { "action": "wait_for_timeout", "timeout": 500 },
        { "action": "click", "target": "[data-testid='export-file-tree'] >> text=SKILL.md >> nth=0" }
      ],
      "assertions": [
        { "type": "textContains", "target": "[data-testid='export-content-preview']", "expected": "user-invocable", "description": "Exported frontmatter contains user-invocable: false field" }
      ]
    }
  ]
}
