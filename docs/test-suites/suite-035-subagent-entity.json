{
  "id": "SUITE-035",
  "name": "Subagent Entity — New Fields & Validation",
  "tests": [
    {
      "id": "TC-307",
      "name": "Subagent editor shows permission mode selector",
      "priority": "high",
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "drag", "target": "[data-testid='palette-item-subagent']", "position": { "x": 500, "y": 300 } },
        { "action": "click", "target": "[data-testid='rf__node-subagent']" }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='field-subagent-permission-mode']", "description": "Permission mode selector is visible in properties panel" }
      ]
    },
    {
      "id": "TC-308",
      "name": "Subagent editor shows bypassPermissions warning",
      "priority": "critical",
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "drag", "target": "[data-testid='palette-item-subagent']", "position": { "x": 500, "y": 300 } },
        { "action": "click", "target": "[data-testid='rf__node-subagent']" },
        { "action": "select", "target": "[data-testid='field-subagent-permission-mode'] select", "value": "bypassPermissions" }
      ],
      "assertions": [
        { "type": "visible", "target": "[data-testid='bypass-permissions-warning']", "description": "Warning about bypassPermissions is shown" }
      ]
    },
    {
