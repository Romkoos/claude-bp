{
  "id": "SUITE-003",
  "name": "Node Creation — Drag & Drop",
  "tests": [
    {
      "id": "TC-020",
      "name": "Create Rules node via drag & drop",
      "priority": "critical",
      "phase": 1,
      "url": "/",
      "steps": [
        { "action": "navigate", "target": "/" },
        { "action": "dragAndDrop", "source": "[data-testid='palette-node-rules']", "target": ".react-flow__pane", "offsetX": 400, "offsetY": 300 }
      ],
      "assertions": [
        { "type": "count", "target": ".react-flow__node[data-type='rules']", "expected": 1, "description": "One Rules node exists on canvas" },
        { "type": "textContains", "target": "[data-testid='status-bar']", "expected": "Nodes: 1", "description": "Status bar shows 1 node" }
      ]
    },
    {
